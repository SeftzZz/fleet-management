				$idAttendant = $this->input->post('idAttendant');
				foreach ($_FILES['file']['name'] as $nmAttendantdetail => $file_name) {
	        if (!empty($file_name)) {
            $upload_path = './assets/images/house_keeping/detail/';
            move_uploaded_file($_FILES['file']['tmp_name'][$nmAttendantdetail], $upload_path . $file_name);
