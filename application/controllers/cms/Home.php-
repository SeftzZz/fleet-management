        'gmail' => $data['customer']->gmail,
        'Bday' => $data['customer']->Bday,
        'addres' => $data['customer']->addres,
        'notel' => $data['customer']->notel
	    );
	    echo json_encode($response, JSON_NUMERIC_CHECK);
		}
	}

