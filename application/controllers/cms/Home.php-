	public function insertFormTypeMeeting($new_invoice_number) {
		$total = $this->input->post('pricePaketmeeting');
		$roompax = $this->input->post('roompaxBooking');
		$pax = $this->input->post('paxBooking');
		$subtotal = $total * $pax;
		$totalPaketmeeting = $subtotal;
