	public function insert_voucher() {
		$extensi = explode(".", $_FILES['imgVoucher']['name']);
		$config['upload_path'] = './assets/images/voucher/';
		$config['allowed_types'] = 'jpg|png|jpeg|pdf';
		$config['max_size'] = 4048000;
		$this->upload->initialize($config);
		if($_FILES['imgVoucher']['name']) {
			if ($extensi[1]=='jpg' || $extensi[1]=='JPG' || $extensi[1]=='png' || $extensi[1]=='jpeg' || $extensi[1]=='pdf') {
				if ($this->upload->do_upload('imgVoucher')) {
					$gbr = $this->upload->data();
					$pictureUrl = $gbr['file_name'];

					$data_voucher = array(
						'nmVoucher' 					=> $this->input->post('nmVoucher'),
						'idBusiness' 					=> $this->session->userdata('idBusiness'),
						'expiredVoucher' 			=> $this->input->post('expiredVoucher'),
						'ketVoucher' 					=> $this->input->post('ketVoucher'),
						'diskonVoucher' 			=> str_replace(',', '', $this->input->post('diskonVoucher')),
						'imgVoucher' 					=> $pictureUrl,
						'idUser'  						=> $this->session->userdata('idUser'),
						'createdAtVoucher'		=> date('Y-m-d H:i:s'),
						);
						$this->db->insert('voucher', $data_voucher);
						$this->session->set_flashdata('pesansukses','Voucher telah dibuat');
						redirect('cms/home/inputBusinessDetail');

				} else {
					$this->session->set_flashdata('pesanerror','file is too large limit size to less than 4MB');							
					redirect('cms/home/viewFnBmenu');
				}
			} else {
				$this->session->set_flashdata('pesanerror','file is not jpg/png');													
				redirect('cms/home/viewFnBmenu');
			}
		} 
	}

	public function insertgambarkamar1($idBusiness) {
		$data=array(
			'title'=>'Madani Djourney | ONIXLABS',
			'nopage'=>11);

    // Get the last inserted ID
		$ketKamar = $this->input->post('ketKamar');
			
